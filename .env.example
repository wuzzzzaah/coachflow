# ── Meta WhatsApp Cloud API ────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=        # Found in Meta Developer App > WhatsApp > API Setup
WHATSAPP_ACCESS_TOKEN=           # Temporary or permanent access token from Meta
WHATSAPP_WEBHOOK_VERIFY_TOKEN=   # Any string you define, used to verify webhook with Meta
WHATSAPP_APP_SECRET=             # App Secret from Meta Developer App > Settings > Basic

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=                  # From Google AI Studio (aistudio.google.com)

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=                    # From Supabase project settings
SUPABASE_ANON_KEY=               # From Supabase project settings
SUPABASE_SERVICE_ROLE_KEY=       # From Supabase project settings (server-side only)

# ── Upstash Redis (replace in-memory sessions for production) ─────────────────
UPSTASH_REDIS_REST_URL=          # From Upstash console
UPSTASH_REDIS_REST_TOKEN=        # From Upstash console

# ── Multi-tenancy ─────────────────────────────────────────────────────────────
DEFAULT_TENANT_ID=               # UUID of the seed tenant (used for local dev)

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
